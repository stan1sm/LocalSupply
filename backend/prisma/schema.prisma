generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum SupplierVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                         String   @id @default(cuid())
  email                      String   @unique
  firstName                  String
  lastName                   String
  passwordHash               String?
  emailVerified              Boolean  @default(false)
  emailVerificationTokenHash String?  @unique
  vippsSub                   String?  @unique
  vippsPhoneNumber           String?
  passwordResetTokenHash     String?  @unique
  passwordResetTokenExpiresAt DateTime?
  accountType                AccountType @default(INDIVIDUAL)
  orgNumber                  String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  orders         Order[]             @relation("BuyerOrders")
  addresses      UserAddress[]
  paymentMethods UserPaymentMethod[]
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  address   String
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model UserPaymentMethod {
  id             String   @id @default(cuid())
  userId         String
  cardholderName String
  maskedNumber   String
  lastFour       String
  expiry         String
  cardType       String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Supplier {
  id                         String                     @id @default(cuid())
  businessName               String
  contactName                String
  phoneNumber                String
  email                      String                     @unique
  passwordHash               String
  address                    String
  orgnr                      String?                    @unique
  isVerified                 Boolean                    @default(false)
  verificationStatus         SupplierVerificationStatus @default(UNVERIFIED)
  verificationRejectedReason String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  // Store profile
  logoUrl               String?
  heroImageUrl          String?
  tagline               String?
  description           String?
  storeType             String?
  badgeText             String?
  brandColor            String?
  serviceRadiusKm       Int?
  serviceAreas          String?
  openingHours          String?
  openingHoursNote      String?
  websiteUrl            String?
  instagramUrl          String?
  facebookUrl           String?
  preferredContactMethod String?
  orderNotesHint        String?
  showInMarketplace     Boolean  @default(true)
  acceptDirectOrders    Boolean  @default(true)
  minimumOrderAmount    Decimal? @db.Decimal(10, 2)

  products Product[]
  orders   Order[]   @relation("SupplierOrders")
}

model Product {
  id          String   @id @default(cuid())
  supplierId  String
  name        String
  description String?
  unit        String
  price       Decimal  @db.Decimal(10, 2)
  stockQty    Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier   Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([supplierId])
  @@index([isActive])
}

model CatalogProduct {
  id         String   @id @default(cuid())
  catalogKey String   @unique
  externalId String?
  gtin       String?
  name       String
  brand      String?
  category   String?
  unit       String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prices CatalogProductPrice[]
  embeddings ProductEmbedding[]

  @@index([externalId])
  @@index([gtin])
  @@index([name])
  @@index([brand])
  @@index([category])
}

model CatalogProductPrice {
  id                   String    @id @default(cuid())
  catalogProductId     String
  externalId           String
  storeCode            String
  storeName            String
  currentPrice         Decimal?  @db.Decimal(10, 2)
  currentUnitPrice     Decimal?  @db.Decimal(10, 2)
  currentUnitPriceUnit String?
  productUrl           String?
  lastCheckedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  catalogProduct CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)

  @@unique([catalogProductId, storeCode])
  @@index([externalId])
  @@index([storeCode])
  @@index([storeCode, currentPrice])
  @@index([storeName])
  @@index([currentPrice])
}

model ProductEmbedding {
  id          String   @id @default(cuid())
  productId   String
  modelName   String
  vectorJson  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, modelName])
  @@index([modelName])
}


model Order {
  id                String      @id @default(cuid())
  buyerId           String
  supplierId        String
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(10, 2)
  deliveryFee       Decimal     @default(0) @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(10, 2)
  notes             String?
  paymentMethod     String?
  deliveryAddressId String?
  woltDeliveryId    String?
  woltTrackingUrl   String?
  woltStatus        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  buyer           User         @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  supplier        Supplier     @relation("SupplierOrders", fields: [supplierId], references: [id], onDelete: Restrict)
  deliveryAddress UserAddress? @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([buyerId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
}
